<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            font-family: 'Arial', sans-serif;
        }
        .blog-container {
            background: rgba(255,255,255,0.95);
            border-radius: 15px;
            padding: 40px;
            margin-top: 30px;
            animation: fadeIn 1s ease-in;
        }
        .navbar {
            background: rgba(0,0,0,0.8) !important;
        }
        .btn-secondary {
            background: linear-gradient(45deg, #74b9ff, #0984e3);
            border: none;
            border-radius: 25px;
            transition: all 0.3s ease;
        }
        .btn-secondary:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(116,185,255,0.4);
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>
    <%- include('partials/nav') %>

    <div class="container">
        <div class="blog-container">
            <a href="/blogs" class="btn btn-secondary mb-4">← Back to Blogs</a>
            <% if (blog.coverImageURL) { %>
                <img src="<%= blog.coverImageURL %>" class="img-fluid rounded mb-4" alt="Cover Image">
            <% } %>
            <h1 class="mb-3"><%= blog.title %></h1>
            <p class="text-muted mb-4">By <%= blog.createdBy.firstname %> on <%= new Date(blog.createdAt).toLocaleDateString() %></p>
            <div class="blog-content mb-5">
                <%- blog.content.replace(/\n/g, '<br>') %>
            </div>

            <div class="comments-section mt-5">
                <h3 class="mb-4">Comments</h3>
                <% if (!comments || comments.length === 0) { %>
                    <p class="text-muted">No comments yet. Be the first to add one.</p>
                <% } else { %>
                    <% comments.forEach((comment) => { %>
                        <div class="card mb-3 shadow-sm">
                            <div class="card-body">
                                <p class="mb-2"><%= comment.text %></p>
                                <p class="mb-0 text-muted small">By <%= comment.createdBy.firstname %> on <%= new Date(comment.createdAt).toLocaleDateString() %></p>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>

            <div class="comment-form mt-5">
                <h3 class="mb-3">Leave a Comment</h3>
                <form action="/blogs/<%= blog._id %>/comments" method="post">
                    <div class="mb-3">
                        <textarea class="form-control" name="comment" rows="4" placeholder="Write your comment..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Post Comment</button>
                </form>
            </div>
        </div>
    </div>

    <%- include('partials/script') %>
</body>
</html>